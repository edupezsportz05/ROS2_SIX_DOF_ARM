<?xml version="1.0"?>
<robot name="six_dof_arm">
  <link name="world"/>
  
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0"/>
  </joint>
  
  <!-- Base link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.2 0.2 0.1"/></geometry>
      <material name="grey"><color rgba="0.6 0.6 0.6 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.2 0.2 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 1 -->
 
   <joint name="joint1_revolute" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5.0" velocity="1.0"/>
    <origin xyz="0 0 0.1"/>
    <dynamics damping="1.0" friction="0.2"/>
   </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.05" length="0.3"/></geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.05" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 2 -->
  <joint name="joint2_revolute" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5.0" velocity="1.0"/>
    <origin xyz="0 0 0.3"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
      <material name="green"><color rgba="0 1 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 3 -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5.0" velocity="1.0"/>
    <origin xyz="0 0 0.3"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 4 -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="5.0" velocity="1.0"/>
    <origin xyz="0 0 0.3"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0.125"/>
      <geometry><cylinder radius="0.03" length="0.25"/></geometry>
      <material name="yellow"><color rgba="1 1 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.125"/>
      <geometry><cylinder radius="0.03" length="0.25"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 5 -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="5.0" velocity="1.0"/>
    <origin xyz="0 0 0.25"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry><cylinder radius="0.025" length="0.2"/></geometry>
      <material name="orange"><color rgba="1 0.5 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1"/>
      <geometry><cylinder radius="0.025" length="0.2"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 6 -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="ee_base"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="5.0" velocity="1.0"/>
    <origin xyz="0 0 0.2"/>
    <dynamics damping="1.0" friction="0.2"/>
  </joint>

  <!-- End effector base -->
  <link name="ee_base">
    <visual>
      <origin xyz="0 0 0.025"/>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025"/>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Tool Center Point -->
  <link name="tool0"/>

  <joint name="tool0_joint" type="fixed">
    <parent link="ee_base"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.05"/>
  </joint>

  <!-- Left finger -->
  <joint name="left_finger_joint" type="prismatic">
    <parent link="ee_base"/>
    <child link="left_finger"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.04" effort="2.0" velocity="0.02"/>
    <origin xyz="0 0.025 0"/>
  </joint>

  <link name="left_finger">
    <visual>
      <origin xyz="0.01 0 0.05"/>
      <geometry><box size="0.02 0.1 0.02"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.01 0 0.05"/>
      <geometry><box size="0.02 0.1 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Right finger (mimic) -->
  <joint name="right_finger_joint" type="prismatic">
    <parent link="ee_base"/>
    <child link="right_finger"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.04" effort="2.0" velocity="0.02"/>
    <origin xyz="0 -0.025 0"/>
    <mimic joint="left_finger_joint" multiplier="-1"/>
  </joint>

  <link name="right_finger">
    <visual>
      <origin xyz="0.01 0 0.05"/>
      <geometry><box size="0.02 0.1 0.02"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.01 0 0.05"/>
      <geometry><box size="0.02 0.1 0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <ros2_control name="SixDOFSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Arm joints -->
    <joint name="joint1_revolute">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint2_revolute">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Gripper -->
    <joint name="left_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>

    <joint name="right_finger_joint">
      <state_interface name="position"/>
    </joint>
  </ros2_control>
  
  <gazebo reference="base_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/home/hecker/dev_ws/install/six_dof_arm/share/six_dof_arm/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
